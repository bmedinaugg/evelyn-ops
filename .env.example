# Evelyn Ops — server-side environment. Copy to .env.local and fill in.
# NOTE: none of these are NEXT_PUBLIC_* — nothing here ships to the browser.

# Supabase project (schema `bot`)
SUPABASE_URL=https://rxnryvwpkdnwkpmhiiup.supabase.co

# Anon/publishable key — used ONLY for the staff auth (login/session) flow.
# It never queries bot.* data in this app.
SUPABASE_ANON_KEY=

# Service-role key — server-only. Used for ALL data access (the RPCs).
# Treat as a secret. Do not expose, do not prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Staff access control
# Any email at this domain may sign in.
STAFF_EMAIL_DOMAIN=urbangymgroup.com
# Optional: comma-separated explicit allow-list. If set, ONLY these emails may
# sign in (domain check still applies). Leave blank to allow the whole domain.
STAFF_ALLOWLIST=

# Anthropic API key — powers the AI fix suggestions on the Feedback inbox.
# Server-only. Get one at https://platform.claude.com
ANTHROPIC_API_KEY=
